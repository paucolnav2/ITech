<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list string="Maintenance Tickets"
                  decoration-danger="state in ('new','opened')"
                  decoration-warning="state in ('assigned','in_progress')"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="priority" widget="priority"/>
                <field name="state"/>
                <field name="assigned_to"/>
                <field name="create_date" string="Detected On"/>
                <field name="close_date"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form string="Maintenance Ticket">
                <header>
                    <button name="action_open"
                            string="Open"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_assign"
                            string="Assign"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'opened' or not assigned_to"/>
                    <button name="action_start"
                            string="Start Intervention"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'assigned'"/>
                    <button name="action_resolve"
                            string="Mark as Resolved"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('assigned','in_progress')"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('resolved','cancelled')"/>
                    <button name="action_reopen"
                            string="Reopen"
                            type="object"
                            invisible="state not in ('resolved','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,opened,assigned,in_progress,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ticket subject..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="assigned_to"/>
                        </group>
                        <group>
                            <field name="create_date" string="Detected On" readonly="1"/>
                            <field name="close_date" readonly="1"
                                   invisible="not close_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Anomaly Details">
                            <field name="description"
                                   placeholder="Anomaly details reported by the IoT backend..."/>
                        </page>
                        <page string="Resolution">
                            <field name="resolution_notes"
                                   placeholder="Describe the corrective actions taken..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_helpdesk_ticket_kanban" model="ir.ui.view">
        <field name="name">helpdesk.ticket.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="assigned_to"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted small">
                                    <field name="create_date" widget="date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="assigned_to" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- Search view -->
    <record id="view_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assigned_to"/>
                <filter string="Active" name="filter_active"
                        domain="[('state','not in',['resolved','cancelled'])]"/>
                <filter string="New" name="filter_new"
                        domain="[('state','=','new')]"/>
                <filter string="Opened" name="filter_opened"
                        domain="[('state','=','opened')]"/>
                <filter string="In Progress" name="filter_in_progress"
                        domain="[('state','in',['assigned','in_progress'])]"/>
                <filter string="Resolved" name="filter_resolved"
                        domain="[('state','=','resolved')]"/>
                <separator/>
                <filter string="Group by State" name="group_state"
                        context="{'group_by':'state'}"/>
                <filter string="Group by Assigned To" name="group_assigned"
                        context="{'group_by':'assigned_to'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_helpdesk_ticket" model="ir.actions.act_window">
        <field name="name">Maintenance Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No maintenance tickets yet.
            </p>
            <p>
                Tickets are created automatically by the IoT backend
                when a sensor detects a critical anomaly.
            </p>
        </field>
    </record>

</odoo>
